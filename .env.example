# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=football_manager
POSTGRES_USER=fm_user
POSTGRES_PASSWORD=fm_password

# JWT
JWT_SECRET=local_dev_secret_change_in_production
JWT_EXPIRES_IN=7d

# Backend
APP_ENV=development
RUN_SEED=true
CORS_ORIGINS=http://localhost:3000

# Daily matchday scheduler: plays each division's round once a day at the
# configured local time (24h). Enable it to run the season in real time.
SCHEDULER_ENABLED=true
MATCHDAY_HOUR=18
MATCHDAY_MINUTE=0

# Frontend (dev only — Next.js proxy para o backend)
BACKEND_INTERNAL_URL=http://backend:3000

# Opcional: override da URL da API no browser (padrão: /api relativo)
# NEXT_PUBLIC_API_URL=/api

# Produção local (docker-compose.prod.yml)
# RUN_SEED=true
